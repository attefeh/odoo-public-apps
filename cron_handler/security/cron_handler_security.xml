<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_cron_handler" model="ir.module.category">
        <field name="name">Cron Handler</field>
        <field name="description">Schedule and run Odoo methods on daily, weekly, or monthly timetables.</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_cron_handler_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_cron_handler"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_cron_handler_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_cron_handler"/>
        <field name="implied_ids" eval="[(4, ref('group_cron_handler_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
