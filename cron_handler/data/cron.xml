<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_dispatch_schedules" model="ir.cron">
        <field name="name">Cron Handler: run scheduled handlers</field>
        <field name="model_id" ref="model_cron_handler"/>
        <field name="state">code</field>
        <field name="code">model.cron_dispatch_all_schedules()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="priority">25</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
